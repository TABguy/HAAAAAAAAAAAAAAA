# Copy to .env and fill in. NEVER commit .env.
AWS_REGION=eu-west-1

# Bedrock model IDs (eu-west-1). Adjust to whatever access is enabled.
BEDROCK_MODEL_ID=eu.ibm.bob-3-5-sonnet-20240620-v1:0
EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# AWS credentials: prefer `aws configure` / SSO / env vars over hardcoding here.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
