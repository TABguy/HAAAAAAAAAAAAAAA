# Secrets — never commit
.env

# Any folder starting with _ (scratch / archives) — org convention
_*/

# Python
venv/
__pycache__/
*.py[cod]
.ipynb_checkpoints/

# Timestamped run outputs (submissions, parsed docs) — regenerated
output/*
!output/.gitkeep

